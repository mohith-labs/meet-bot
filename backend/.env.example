PORT=3001
JWT_SECRET=your-super-secret-key-change-in-production
DB_PATH=.data/database.sqlite
FRONTEND_URL=http://localhost:3000
BOT_NAME=MeetBot

# Google account for the bot (a secondary Google account, NOT your primary)
GOOGLE_ACCOUNT_EMAIL=
GOOGLE_ACCOUNT_PASSWORD=
# Path to the Playwright auth state file (generated by npm run gen:auth)
AUTH_STATE_PATH=./auth.json

# Google OAuth for bot authentication (optional — allows users to connect Google accounts via Settings)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Override the OAuth redirect URI (defaults to FRONTEND_URL/settings/oauth/callback)
# GOOGLE_OAUTH_REDIRECT_URI=

# Directory for per-user auth state files (defaults to .data/auth/)
# AUTH_DATA_DIR=.data/auth

# Admin account (created automatically on first startup)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# Registration
REGISTRATION_ENABLED=true
